# Kafka (host machine talks to Redpanda exposed port)
KAFKA_BOOTSTRAP_SERVERS=localhost:19092

# Shared local Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=humanize
POSTGRES_USER=humanize
POSTGRES_PASSWORD=humanize

# Auth service
AUTH_DB_URL=jdbc:postgresql://localhost:5432/humanize
AUTH_DB_USERNAME=humanize
AUTH_DB_PASSWORD=humanize
AUTH_DB_DRIVER=org.postgresql.Driver
AUTH_DB_DDL_AUTO=validate
AUTH_FLYWAY_ENABLED=true
AUTH_FLYWAY_BASELINE_ON_MIGRATE=true
AUTH_JWT_SECRET=dev-secret-change-me
AUTH_ISSUER=humanize-auth
GOOGLE_CLIENT_ID=

# Library service
LIBRARY_DB_URL=jdbc:postgresql://localhost:5432/humanize
LIBRARY_DB_USERNAME=humanize
LIBRARY_DB_PASSWORD=humanize
LIBRARY_DB_DRIVER=org.postgresql.Driver
LIBRARY_DB_DDL_AUTO=validate
LIBRARY_FLYWAY_ENABLED=true
LIBRARY_FLYWAY_BASELINE_ON_MIGRATE=true
R2_ACCOUNT_ID=
R2_ENDPOINT=
R2_BUCKET=humanize-books
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_UPLOAD_URL_TTL_MINUTES=15

# Ingestion service
INGESTION_DB_URL=jdbc:postgresql://localhost:5432/humanize
INGESTION_DB_USERNAME=humanize
INGESTION_DB_PASSWORD=humanize
INGESTION_DB_DRIVER=org.postgresql.Driver
INGESTION_DB_DDL_AUTO=validate
INGESTION_FLYWAY_ENABLED=true
INGESTION_FLYWAY_BASELINE_ON_MIGRATE=true
INGESTION_LOCAL_SOURCE_ROOT=
INGESTION_MIN_EXTRACTED_CHARS=400
INGESTION_OCR_ENABLED=true
INGESTION_OCR_COMMAND=tesseract
INGESTION_OCR_TIMEOUT_SECONDS=45

# Reader service
READER_DB_URL=jdbc:postgresql://localhost:5432/humanize
READER_DB_USERNAME=humanize
READER_DB_PASSWORD=humanize
READER_DB_DRIVER=org.postgresql.Driver
READER_DB_DDL_AUTO=validate
READER_FLYWAY_ENABLED=true
READER_FLYWAY_BASELINE_ON_MIGRATE=true

# Activity service
ACTIVITY_DB_URL=jdbc:postgresql://localhost:5432/humanize
ACTIVITY_DB_USERNAME=humanize
ACTIVITY_DB_PASSWORD=humanize
ACTIVITY_DB_DRIVER=org.postgresql.Driver
ACTIVITY_DB_DDL_AUTO=validate
ACTIVITY_FLYWAY_ENABLED=true
ACTIVITY_FLYWAY_BASELINE_ON_MIGRATE=true

# Recommendation service
RECO_DB_URL=jdbc:postgresql://localhost:5432/humanize
RECO_DB_USERNAME=humanize
RECO_DB_PASSWORD=humanize
RECO_DB_DRIVER=org.postgresql.Driver
RECO_DB_DDL_AUTO=validate
RECO_FLYWAY_ENABLED=true
RECO_FLYWAY_BASELINE_ON_MIGRATE=true
